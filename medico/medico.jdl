entity Medico {

    nombre String required minlength(2) maxlength(100),
    especialidad String required minlength(3) maxlength(100),
    telefono String minlength(10) maxlength(15),
    turno String minlength(3) maxlength(50),
    activo Boolean required
}

paginate Medico with pagination
dto Medico with mapstruct
service Medico with serviceImpl
